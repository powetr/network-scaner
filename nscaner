#!/bin/bash

# ==============================================================================
# СЕТЕВОЙ СКАНЕР И МОНИТОР БЕЗОПАСНОСТИ (v3.27 Final-Stable Edition)
# ==============================================================================
# ПОДДЕРЖКА: Zabbix LLD, Syslog, Multi-Lang, Calendar History Filter.
# ИСПРАВЛЕНО: Экспорт (-E) и создание пустых файлов алертов.
# ==============================================================================

VERSION="3.27"
LANG_SET="ru" 

# --- ПАРАМЕТРЫ ПО УМОЛЧАНИЮ ---
IFACE=""; THREADS=50; PING_THRESHOLD=100; OUT_FORMAT="text"
SHOW_NAMES=false; NAME_FILTER=""; SORT_ORDER="none"; USE_COLOR=false
ACTIVITY_TARGET=""; USE_SYSLOG=false; SYSLOG_HOST=""
ALERT_ONLY=false; DAYS_CLEAN=0; DO_CLEAR=false; DO_EXPORT=false; LIMIT_ONLY=false
SINGLE_IP=""; MAC_MOD=""

# --- ЦВЕТА ---
CLR_YEL='\033[1;33m'; CLR_GRN='\033[0;32m'; CLR_WHT='\033[1;37m'
CLR_ORN='\033[38;5;208m'; CLR_RED='\033[0;31m'; CL_OFF='\033[0m'

# --- ЛОКАЛИЗАЦИЯ ---
set_language() {
    if [[ "$LANG_SET" == "en" ]]; then
        MSG_TITLE="NETWORK MONITOR v$VERSION"; MSG_USAGE="Usage: $0 -i <interface> [options]"
        MSG_SCAN_ERR="Interface error."; MSG_SORT="SORT: -o asc/desc"
        MSG_HIST_EMPTY="No records found for the last %s."; MSG_ANALYSIS="=== ANALYSIS FOR IP: %s (%s) ==="
        MSG_ONLINE="Online"; MSG_OFFLINE="Offline"
        MSG_STATS="[STATS] Total: %d | Online: %d | Avg: %s | Peak: %s | Ratio: %s%%"
        MSG_ALERT="ALERT: %s MAC CHANGED %s -> %s (%s)"; MSG_CLEAN="Cleanup complete (%s days)."
        MSG_EXPORT="Export complete: %s"; MSG_ALL_TIME="all time"; MSG_DAYS_LONG="days"
    else
        MSG_TITLE="СЕТЕВОЙ МОНИТОР v$VERSION"; MSG_USAGE="Использование: $0 -i <interface> [опции]"
        MSG_SCAN_ERR="Ошибка интерфейса."; MSG_SORT="СОРТИРОВКА: -o asc/desc"
        MSG_HIST_EMPTY="Нет записей за последние %s."; MSG_ANALYSIS="=== АНАЛИЗ IP: %s (%s) ==="
        MSG_ONLINE="В сети"; MSG_OFFLINE="Вне сети"
        MSG_STATS="[СТАТ] Всего: %d | В сети: %d | Средний: %s | Пик: %s | Соотношение: %s%%"
        MSG_ALERT="ALERT: %s MAC ИЗМЕНЕН %s -> %s (%s)"; MSG_CLEAN="Очистка завершена (%s дн.)."
        MSG_EXPORT="Экспорт завершен: %s"; MSG_ALL_TIME="за всё время"; MSG_DAYS_LONG="дн."
    fi
}

for ((i=1; i<=$#; i++)); do [[ "${!i}" == "-g" ]] && { next=$((i+1)); LANG_SET="${!next}"; }; done
set_language

format_mac_strict() {
    local raw="${1//:/}"; local mod="$2"
    [[ -z "$raw" || "$raw" == "-" ]] && { echo "$raw"; return; }
    case "$mod" in
        1) local up="${raw^^}"; echo "$up" | sed 's/.\{2\}/&:/g; s/:$//' ;;
        2) echo "${raw,,}" ;;
        3) echo "${raw^^}" ;;
        *) local lo="${raw,,}"; echo "$lo" | sed 's/.\{2\}/&:/g; s/:$//' ;;
    esac
}

send_to_syslog() {
    [[ "$USE_SYSLOG" == "false" || -z "$1" ]] && return
    echo -e "$1" | sed 's/\x1b\[[0-9;]*m//g; s/\t/ /g' | while read -r line; do
        [[ -z "$line" ]] && continue
        [[ -z "$SYSLOG_HOST" ]] && logger -t net_scan "$line" || logger -n "$SYSLOG_HOST" -t net_scan "$line"
    done
}

usage() {
    echo -e "${CLR_YEL}${MSG_TITLE}${CL_OFF}" >&2
    echo -e "${MSG_USAGE}" >&2
    echo -e "\n${CLR_WHT}СЕТЕВЫЕ НАСТРОЙКИ:${CL_OFF}"
    echo -e "  -i <iface>      Сетевой интерфейс (например, eth0, wlan0)"
    echo -e "  -S <ip>         Сканировать только ОДИН конкретный IP-адрес"
    echo -e "  -t <threads>    Количество потоков сканирования (по умолчанию: 50)"
    echo -e "  -p <ms>         Порог пинга для фильтрации/подсветки (по умолчанию: 100)"
    echo -e "\n${CLR_WHT}ФОРМАТИРОВАНИЕ MAC (-m):${CL_OFF}"
    echo -e "  -m 1            Верхний регистр (дефолт для -A)"
    echo -e "  -m 2            Без разделителей (aabbcc...)"
    echo -e "  -m 3            Верхний регистр и без разделителей"
    echo -e "\n${CLR_WHT}ЛОГИКА ИМЕН ХОСТОВ (-n):${CL_OFF}"
    echo -e "  -n              Вывести ТОЛЬКО устройства с именами"
    echo -e "  -n all          Вывести ВСЕ найденные устройства"
    echo -e "  -n <string>     Фильтр по имени хоста"
    echo -e "\n${CLR_WHT}ВЫВОД И МОНИТОРИНГ:${CL_OFF}"
    echo -e "  -o <asc|desc>   Сортировка по пингу"
    echo -e "  -f <format>     Формат: text (default) или json (Zabbix LLD)"
    echo -e "  -c              Включить цветную подсветку"
    echo -e "  -q              Alert Mode: вывод только изменений MAC-адресов"
    echo -e "  -L              Limit Mode: только хосты с пингом >= порога (-p)"
    echo -e "\n${CLR_WHT}АНАЛИЗ И ЛОГИ:${CL_OFF}"
    echo -e "  -A <ip>         Анализ истории IP (MAC дефолт: 1)"
    echo -e "  -d <days>       Период анализа / срок хранения"
    echo -e "  -s [host]       Отправка лога в Syslog"
    echo -e "  -E              Экспорт всей базы"
    echo -e "  -X              Принудительная очистка базы"
    echo -e "  -g <ru|en>      Смена языка интерфейса"
    echo -e "  -v              Показать версию"
    exit 1
}

while getopts "i:t:p:cnA:o:sf:qXEg:d:vLS:m:" opt; do
    case $opt in
        i) IFACE="$OPTARG" ;;
        t) THREADS="$OPTARG" ;;
        p) PING_THRESHOLD="$OPTARG" ;;
        c) USE_COLOR=true ;;
        n) SHOW_NAMES=true; nv="${!OPTIND}"; if [[ -n "$nv" && ! "$nv" =~ ^- ]]; then NAME_FILTER="$nv"; OPTIND=$((OPTIND+1)); fi ;;
        A) ACTIVITY_TARGET="$OPTARG" ;;
        o) SORT_ORDER="$OPTARG" ;;
        s) USE_SYSLOG=true; sv="${!OPTIND}"; if [[ -n "$sv" && ! "$sv" =~ ^- ]]; then SYSLOG_HOST="$sv"; OPTIND=$((OPTIND+1)); fi ;;
        f) OUT_FORMAT="$OPTARG" ;;
        q) ALERT_ONLY=true ;;
        X) DO_CLEAR=true ;;
        E) DO_EXPORT=true ;;
        g) LANG_SET="$OPTARG"; set_language ;;
        d) DAYS_CLEAN="$OPTARG" ;;
        L) LIMIT_ONLY=true ;;
        S) SINGLE_IP="$OPTARG" ;;
        m) MAC_MOD="$OPTARG" ;;
        v) echo "Version: $VERSION"; exit 0 ;;
        *) usage ;;
    esac
done

cd "$(dirname "$0")" || exit 1

# --- 1. ТЕРМИНАЛЬНЫЕ ФУНКЦИИ (ИСПРАВЛЕНО -E) ---
if [[ "$DO_CLEAR" == "true" ]]; then
    CV=${DAYS_CLEAN:-30}; find scans -type f -name "scan_*.txt" -mtime +"$CV" -delete
    find . -maxdepth 1 -type f -name "alerts_*.log" -mtime +"$CV" -delete; printf "$MSG_CLEAN\n" "$CV"; exit 0
fi

if [[ "$DO_EXPORT" == "true" ]]; then
    EXPORT_FILE="export_$(date +%F_%H%M).txt"
    [[ -d "scans" ]] && find scans -type f -name "scan_*.txt" -exec cat {} + > "$EXPORT_FILE"
    if [[ -s "$EXPORT_FILE" ]]; then printf "$MSG_EXPORT\n" "$EXPORT_FILE"; else echo "Export: No data found."; rm -f "$EXPORT_FILE"; fi
    exit 0
fi

# --- 2. АНАЛИЗ ИСТОРИИ (-A) ---
if [[ -n "$ACTIVITY_TARGET" ]]; then
    [[ -z "$MAC_MOD" ]] && MAC_MOD=1
    ALL_FILES=$(find scans -type f -name "scan_*.txt" | sort 2>/dev/null)
    [[ -z "$ALL_FILES" ]] && { echo "History empty"; exit 0; }
    if [[ -n "$DAYS_CLEAN" && "$DAYS_CLEAN" -gt 0 ]]; then
        TH_D=$(date -d "$DAYS_CLEAN days ago 00:00:00" +%s); PER_STR="$DAYS_CLEAN $MSG_DAYS_LONG"
    else TH_D=0; PER_STR="$MSG_ALL_TIME"; fi
    printf "${CLR_WHT}$(printf "$MSG_ANALYSIS" "$ACTIVITY_TARGET" "$PER_STR")${CL_OFF}\n"
    T_S=0; T_O=0; S_P=0; P_P=0
    while read -r file; do
        FB=$(basename "$file"); FD=$(echo "$FB" | cut -d'_' -f2); FH=$(echo "$FB" | cut -d'_' -f3); FM=$(echo "$FB" | cut -d'_' -f4 | cut -d'.' -f1)
        F_TS=$(date -d "$FD $FH:$FM" +%s 2>/dev/null); [[ $TH_D -gt 0 && $F_TS -lt $TH_D ]] && continue
        ((T_S++)); MATCH=$(grep -m 1 "^$ACTIVITY_TARGET" "$file")
        if [[ -n "$MATCH" ]]; then 
            ((T_O++)); MH_R=$(echo "$MATCH" | awk '{print $2}'); PH=$(echo "$MATCH" | awk '{print $3}')
            MH=$(format_mac_strict "$MH_R" "$MAC_MOD")
            S_P=$(echo "$S_P + $PH" | bc -l); [[ $(echo "$PH > $P_P" | bc -l) -eq 1 ]] && P_P=$PH
            if [[ "$USE_COLOR" == "true" ]]; then
                [[ $(echo "$PH >= ${PING_THRESHOLD:-100}" | bc -l) -eq 1 ]] && PD="$CLR_RED$PH${CL_OFF}" || PD="$CLR_ORN$PH${CL_OFF}"
                REP="[$FD $FH:$FM] $CLR_GRN$MSG_ONLINE${CL_OFF} MAC: $CLR_WHT$MH${CL_OFF} Ping: $PD"
            else REP="[$FD $FH:$FM] $MSG_ONLINE MAC: $MH Ping: $PH"; fi
            [[ "$USE_SYSLOG" == "true" ]] && send_to_syslog "[$FD $FH:$FM] $MSG_ONLINE MAC: $MH Ping: $PH"
        else REP="[$FD $FH:$FM] $MSG_OFFLINE"; [[ "$USE_SYSLOG" == "true" ]] && send_to_syslog "$REP"; fi
        echo -e "$REP"
    done <<< "$ALL_FILES"
    if [[ $T_O -gt 0 ]]; then
        AVG=$(echo "scale=2; $S_P / $T_O" | bc -l); RATIO=$(echo "scale=1; ($AVG / $P_P) * 100" | bc -l)
        ST_M=$(printf "$MSG_STATS" "$T_S" "$T_O" "$AVG" "$P_P" "$RATIO")
        echo -e "\n${CLR_WHT}${ST_M}${CL_OFF}"; [[ "$USE_SYSLOG" == "true" ]] && send_to_syslog "$ST_M"
    fi; exit 0
fi

# --- 3. ОСНОВНОЙ СКАН ---
if [[ -z "$IFACE" ]]; then usage; fi
[[ -z "$MAC_MOD" ]] && MAC_MOD=0
ip link show "$IFACE" &>/dev/null || { echo "Err: $IFACE"; exit 1; }
S_IP=$(ip -o -4 addr show "$IFACE" | awk '{print $4}' | cut -d/ -f1); S_MAC=$(ip link show "$IFACE" | awk '/ether/ {print $2}')
IP_L=$([[ -n "$SINGLE_IP" ]] && echo "$SINGLE_IP" || printf "%s\n" {1..254} | awk -v p="$(echo "$S_IP" | cut -d. -f1-3)" '{print p "." $1}')
FILE_DT=$(date +"%Y-%m-%d_%H_%M"); M_D=$(date +%m_%Y); D_D=$(date +%d); mkdir -p "scans/$M_D/$D_D"
OUT="scans/$M_D/$D_D/scan_${FILE_DT}.txt"; L_SC=$(find scans -type f -name "scan_*.txt" | sort | tail -n 2 | head -n 1)

RESULT=$(echo "$IP_L" | xargs -I {} -P "$THREADS" bash -c '
    IP="{}"; IFACE="$1"; S_IP="$2"; S_MAC="$3"; SH_NM="$4"; MOD="$5"
    if ping -c 1 -W 0.8 "$IP" >/dev/null 2>&1; then
        T=$(ping -c 1 -W 1 "$IP" | grep -oP "time=\K[0-9.]+")
        [[ -z "$T" ]] && T="0.01"
        if [[ "$IP" == "$S_IP" ]]; then M="$S_MAC"
        else M=$(ip neigh show dev "$IFACE" "$IP" | awk "{print \$5}")
             [[ ( -z "$M" || ${#M} -lt 12 ) ]] && M=$(arp -n -i "$IFACE" "$IP" | grep -oE "([0-9a-fA-F]{2}:){5}[0-9a-fA-F]{2}"); fi
        if [[ -n "$M" && ( ${#M} -eq 17 || ${#M} -eq 12 ) ]]; then
            [[ "$MOD" == "1" ]] && M="${M^^}"; [[ "$MOD" == "2" ]] && M="${M//:/}"; [[ "$MOD" == "3" ]] && { M="${M^^}"; M="${M//:/}"; }
            NAME="-"; if [[ "$SH_NM" == "true" ]]; then
                NAME=$(getent hosts "$IP" | awk "{print \$2}"); [[ -z "$NAME" ]] && NAME=$(timeout 0.3 avahi-resolve -a "$IP" 2>/dev/null | awk "{print \$2}")
                [[ -z "$NAME" ]] && NAME="-"; fi
            printf "%s\t%s\t%s\t%s\n" "$IP" "$M" "$T" "$NAME"
        fi
    fi' -- "$IFACE" "$S_IP" "$S_MAC" "$SHOW_NAMES" "$MAC_MOD")

if [ -n "$RESULT" ]; then
    [[ -z "$SINGLE_IP" ]] && echo "$RESULT" | awk '{print $1 "\t" $2 "\t" $3}' | sort -k1V > "$OUT"
    PM_S=""; [[ -f "$L_SC" ]] && PM_S=$(awk '{print $1"|"$2}' "$L_SC")

    FILTERED=$(echo "$RESULT" | awk -v sn="$SHOW_NAMES" -v nf="$NAME_FILTER" -v lim="$PING_THRESHOLD" -v lo="$LIMIT_ONLY" -v qm="$ALERT_ONLY" -v pm_str="$PM_S" '
    BEGIN { split(pm_str, ah, " "); for(k in ah) { split(ah[k], tv, "|"); if(tv[1]!="") { mc=tolower(tv[2]); gsub(":","",mc); hm[tv[1]]=mc } } }
    { cmc=tolower($2); gsub(":","",cmc); if(lo=="true" && $3 < lim) next; if(qm=="true" && (hm[$1] == "" || hm[$1] == cmc)) next;
      if(sn=="true"){ if(nf=="all" || nf==""){ if($4!="-"){print $0;next} next }
      if(index(tolower($4),tolower(nf))>0){print $0;next} next } print $0 }')

    if [[ "$OUT_FORMAT" == "json" ]]; then
        echo "$FILTERED" | awk 'BEGIN { print "{\"data\":[" } { if ($1!="") { if (cnt>0) printf ",\n"; printf "{\"{#IP}\":\"%s\", \"{#MAC}\":\"%s\", \"{#PING}\":%s}", $1, $2, $3; cnt++; } } END { print "\n]}" }'
    else
        [[ "$SORT_ORDER" == "asc" ]] && FILTERED=$(echo "$FILTERED" | sort -k3n); [[ "$SORT_ORDER" == "desc" ]] && FILTERED=$(echo "$FILTERED" | sort -k3nr)
        echo "$FILTERED" | awk -v y="$CLR_YEL" -v o="$CLR_ORN" -v r="$CLR_RED" -v off="$CL_OFF" -v clr="$USE_COLOR" -v pm_str="$PM_S" -v lim="$PING_THRESHOLD" -v sn="$SHOW_NAMES" '
        BEGIN { split(pm_str, ah, " "); for(k in ah) { split(ah[k], tv, "|"); if(tv[1]!="") { mc=tolower(tv[2]); gsub(":","",mc); hm[tv[1]]=mc } } }
        { cmc=tolower($2); gsub(":","",cmc); m_disp = $2; if(clr=="true" && hm[$1]!="" && hm[$1]!=cmc) m_disp = o $2 off;
          p_disp = $3; if(clr=="true" && $3 >= lim) p_disp = r $3 off;
          if(sn=="true") print (clr=="true"?y $4 off:$4) "\t" $1 "\t" m_disp "\t" p_disp
          else print (clr=="true"?y $1 off:$1) "\t" m_disp "\t" p_disp }'
    fi
    [[ "$USE_SYSLOG" == "true" ]] && send_to_syslog "$(echo "$FILTERED" | awk '{print $1 "\t" $2 "\t" $3}')"

    # --- ИСПРАВЛЕНО: ФАЙЛ ALERTS СОЗДАЕТСЯ ТОЛЬКО ПРИ НАЛИЧИИ ДАННЫХ ---
    ALERTS_RAW=$(echo "$RESULT" | awk -v pm_str="$PM_S" -v fmt="$MSG_ALERT" '
    BEGIN { split(pm_str, ah, " "); for(k in ah) { split(ah[k], tv, "|"); if(tv[1]!="") { mc=tolower(tv[2]); gsub(":","",mc); hm[tv[1]]=mc; hr[tv[1]]=tv[2] } } }
    { cmc=tolower($2); gsub(":","",cmc); if (hm[$1] != "" && hm[$1] != cmc) printf fmt "\n", $1, toupper(hr[$1]), toupper($2), $4 }')
    
    if [[ -n "$ALERTS_RAW" ]]; then echo -e "$ALERTS_RAW" > "alerts_${FILE_DT}.log"; fi
fi
